# MongoDB Connection (must match backend)
MONGODB_URL=mongodb://localhost:27017
MONGODB_DB=translation_bot
ADMIN_JWT_SECRET=generate-a-unique-random-secret-for-admin-only
ADMIN_JWT_ALGORITHM=HS256
ADMIN_ACCESS_TOKEN_EXPIRE_MINUTES=15
ADMIN_REFRESH_TOKEN_EXPIRE_DAYS=7
ADMIN_TOKEN_ISSUER=giftme-admin-api
ADMIN_TOKEN_AUDIENCE=admin.giftme.watch
ADMIN_COOKIE_SECURE=false
ADMIN_COOKIE_SAMESITE=strict
ADMIN_COOKIE_DOMAIN=
ADMIN_BOOTSTRAP_CODE=replace-with-a-one-time-initial-admin-code
ADMIN_INVITE_EXPIRE_HOURS=24
PUBLIC_BACKEND_URL=http://127.0.0.1:8000
REDIS_URL=redis://localhost:6379/0
CONTROL_PLANE_SECRET=use-the-same-long-secret-in-admin-and-user-backend
CONTROL_PLANE_ACK_TIMEOUT_SECONDS=4
LIBRETRANSLATE_URL=http://127.0.0.1:5000
HEALTH_VERIFY_TLS=true
MEDIA_ROOT=./data/media
MAX_UPLOAD_MB=25
ADMIN_FRONTEND_ORIGINS=http://localhost:5176,http://127.0.0.1:5176
PUBLIC_CONTENT_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,https://giftme.watch
