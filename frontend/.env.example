# Public frontend URL (used in meeting invitation links)
# For local testing: replace with your computer's LAN IP
# For production: use the actual domain
VITE_PUBLIC_APP_URL=https://giftme.watch

# API endpoints (optional - auto-detects from frontend host if not set)
# Local development example:
# VITE_API_BASE_URL=https://192.168.1.100:8000
# VITE_WS_BASE_URL=wss://192.168.1.100:8000/ws

# Production URLs (will be set during build)
VITE_API_BASE_URL=https://api.giftme.watch
VITE_WS_BASE_URL=wss://api.giftme.watch/ws  