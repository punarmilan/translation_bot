# PRODUCTION DEPLOYMENT CONFIGURATION
# ====================================
# Generate all REPLACE-WITH values using: openssl rand -hex 32 or -hex 64
# Never commit this file to version control!

# TLS Certificate (Let's Encrypt)
ACME_EMAIL=your-email@example.com

# MongoDB Credentials (URL-safe: letters, digits, _, -)
# Generate with: openssl rand -hex 32
MONGO_ROOT_USERNAME=giftme_root
MONGO_ROOT_PASSWORD=REPLACE-WITH-32-CHAR-RANDOM-VALUE
MONGO_APP_USERNAME=giftme_app
MONGO_APP_PASSWORD=REPLACE-WITH-32-CHAR-RANDOM-VALUE
MONGODB_DB=translation_bot
MONGODB_SERVER_SELECTION_TIMEOUT_MS=5000

# Authentication (both APIs must use the same JWT_SECRET)
# Generate with: openssl rand -hex 64
JWT_SECRET=REPLACE-WITH-64-CHAR-RANDOM-VALUE
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Translation & Speech Processing
TRANSLATION_TIMEOUT_SECONDS=15
TRANSLATION_CACHE_MAX_SIZE=2048
MIN_DETECTION_CONFIDENCE=0.72

# Speech Recognition (Faster Whisper)
STT_PROVIDER=faster_whisper
WHISPER_MODEL=base
WHISPER_DEVICE=cpu
WHISPER_COMPUTE_TYPE=int8
WHISPER_BEAM_SIZE=5
WHISPER_VAD_MIN_SILENCE_MS=700

# Text-to-Speech (Piper)
TTS_PROVIDER=piper
PIPER_TIMEOUT_SECONDS=45

# WebRTC TURN Relay
# Set TURN_EXTERNAL_IP to your VPS public IPv4 address
TURN_HOST=api.giftme.watch
TURN_PORT=3478
TURN_EXTERNAL_IP=YOUR-VPS-PUBLIC-IP-ADDRESS
# Generate with: openssl rand -hex 64
TURN_SHARED_SECRET=REPLACE-WITH-64-CHAR-RANDOM-VALUE
TURN_CREDENTIAL_TTL_SECONDS=3600

# Frontend Origins (must match your domain)
FRONTEND_ORIGINS=https://giftme.watch
ADMIN_FRONTEND_ORIGINS=https://admin.giftme.watch

# Container Image References (set by deploy.sh)
IMAGE_PREFIX=ghcr.io/owner/repository
IMAGE_TAG=latest
