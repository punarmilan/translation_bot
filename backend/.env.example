# MongoDB Connection
MONGODB_URL=mongodb://localhost:27017
MONGODB_DB=translation_bot
MONGODB_SERVER_SELECTION_TIMEOUT_MS=5000
REDIS_URL=redis://localhost:6379/0
CONTROL_PLANE_SECRET=use-the-same-long-secret-in-admin-and-user-backend

# Authentication
JWT_SECRET=change-this-to-a-long-random-string-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Translation Service
LIBRETRANSLATE_URL=http://127.0.0.1:5000
TRANSLATION_TIMEOUT_SECONDS=15
TRANSLATION_CACHE_MAX_SIZE=2048

# Speech Recognition (Whisper)
STT_PROVIDER=faster_whisper
WHISPER_MODEL=base
WHISPER_DEVICE=cpu
WHISPER_COMPUTE_TYPE=int8
WHISPER_BEAM_SIZE=5
WHISPER_VAD_MIN_SILENCE_MS=700
MIN_DETECTION_CONFIDENCE=0.72
HF_HUB_DISABLE_XET=1

# Text-to-Speech (Piper)
TTS_PROVIDER=piper
PIPER_EXECUTABLE=C:\piper\piper.exe
PIPER_TIMEOUT_SECONDS=45
# Override these only if voices are in a custom location:
# PIPER_VOICE_MODEL_EN=C:\path\to\en_US-amy-medium.onnx
# PIPER_VOICE_CONFIG_EN=C:\path\to\en_US-amy-medium.onnx.json

# CORS Settings
FRONTEND_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
CORS_ORIGIN_REGEX=
