MONGODB_URL=mongodb://localhost:27017
MONGODB_DB=translation_bot
JWT_SECRET=change-this-to-a-long-random-string-in-production
LIBRETRANSLATE_URL=http://127.0.0.1:5000

WHISPER_MODEL=base
WHISPER_DEVICE=cpu
WHISPER_COMPUTE_TYPE=int8
HF_HUB_DISABLE_XET=1

PIPER_EXECUTABLE=C:\piper\piper.exe
# The downloader stores voices in backend\models\piper by default.
# Override these only if your Piper voices live somewhere else.
# PIPER_VOICE_MODEL_EN=C:\path\to\en_US-amy-medium.onnx
# PIPER_VOICE_CONFIG_EN=C:\path\to\en_US-amy-medium.onnx.json
